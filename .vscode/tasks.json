{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Jenkins: Start",
            "type": "shell",
            "command": "docker compose up -d --build",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            },
            "problemMatcher": []
        },
        {
            "label": "Jenkins: Stop",
            "type": "shell",
            "command": "docker compose down",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            },
            "problemMatcher": []
        },
        {
            "label": "Jenkins: Restart",
            "type": "shell",
            "command": "docker compose restart jenkins",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            },
            "problemMatcher": []
        },
        {
            "label": "Jenkins: Logs (live)",
            "type": "shell",
            "command": "docker compose logs -f jenkins",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Jenkins: Get Admin Password",
            "type": "shell",
            "command": "docker exec devsecops-jenkins cat /var/jenkins_home/secrets/initialAdminPassword",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            },
            "problemMatcher": []
        },
        {
            "label": "Jenkins: Open in Browser",
            "type": "shell",
            "command": "Start-Process 'http://localhost:8080'",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
